# ── Gemini AI ──
GEMINI_API_KEY=your_gemini_key_here

# ── Stellar Network ──
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Soroban Agent Contract (set after running contracts/scripts/deploy.sh) ──
NEXT_PUBLIC_AGENT_CONTRACT_ID=CAGIKMTM5ZGZZLYDHFI3EOI6GTJX7ODAJN2PW4JXNMNXKOFD5FBTQJKB

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database / Supabase (REQUIRED for production) ──
DATABASE_URL=postgresql://user:password@db.xxxxx.supabase.co:5432/postgres
AGENT_STORE_BACKEND=prisma

# Supabase credentials for analytics/user tracking
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx...

# ── Agent Store Backend - DEPRECATED (use Supabase) ──
# json | redis (legacy - kept for backwards compatibility)
# AGENT_STORE_BACKEND=json

# Redis (Upstash REST) - optional legacy backend
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AGENTS_STORE_REDIS_KEY=agents:all

# ── Cron (Phase 1) ──
# If set, /api/cron/* endpoints require Authorization: Bearer $CRON_SECRET
CRON_SECRET=
CRON_MAX_AGENTS_PER_RUN=25
ENABLE_ASSISTED_AUTO=true
ENABLE_FULL_AUTO=false

# ── Reminders (Phase 1) ──
RESEND_API_KEY=
REMINDER_FROM_EMAIL=
TELEGRAM_BOT_TOKEN=

# ── Full Auto Security (Phase 3) ──
# Must be base64-encoded 32-byte key for AES-256-GCM.
AUTO_SIGNING_MASTER_KEY=
